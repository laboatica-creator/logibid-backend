{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["server.ts", "src/config/**/*", "src/controllers/**/*", "src/middlewares/**/*", "src/repositories/**/*", "src/routes/**/*", "src/services/**/*", "src/socket/**/*"],
  "exclude": ["node_modules", "dist", "src/App.tsx", "src/main.tsx", "src/index.css", "src/assets", "src/hooks", "src/pages", "src/components"]
}